# Copy this file to .env and fill in real values. .env is gitignored.

# --- Required ---
DISCORD_TOKEN=your-discord-bot-token
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Optional (shown with defaults) ---
# Which Claude model answers. Haiku is cheapest/fastest for casual Q&A.
MODEL=claude-haiku-4-5

# Hard ceiling on a single answer's length/cost (tokens).
MAX_TOKENS=1024

# Daily global token budget. Bot disables itself once exceeded (resets at UTC midnight).
DAILY_TOKEN_BUDGET=200000

# Persona / instructions sent to Claude on every call.
SYSTEM_PROMPT=You are a concise, helpful assistant answering questions in a Discord server. Prefer clear, direct answers.

# During development: a server (guild) ID to sync the /ask command to instantly.
# Leave blank to sync globally (can take up to an hour to appear).
DEV_GUILD_ID=

# --- Access controls (v2) ---
# Comma-separated guild IDs allowed to use the bot. Empty = allow all servers.
ALLOWED_GUILD_IDS=
# Minimum seconds between one user's requests. 0 = no cooldown.
USER_COOLDOWN_SECONDS=0

# --- Conversation memory (v2) ---
# Max turns (user+assistant messages) kept as context for a follow-up.
HISTORY_MAX_MESSAGES=8
# Forget a conversation after this many minutes of inactivity.
MEMORY_TTL_MINUTES=60
# Cap on stored conversations (oldest evicted past this).
MEMORY_MAX_CONVERSATIONS=500

# --- Persistence (v2) ---
# File where the daily token budget is saved so it survives restarts.
BUDGET_FILE=data/budget.json
